{
  "name": "futuresightml",
  "version": "0.1.0",
  "description": "FutureSightML - Pokemon Team Builder powered by ML",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-mac-x64": "electron-builder --mac --x64",
    "build-mac-arm64": "electron-builder --mac --arm64",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.futuresightml.app",
    "productName": "FutureSightML",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ],
      "icon": "static/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        {
          "target": "dir",
          "arch": ["universal"]
        }
      ],
      "icon": "static/icon.png",
      "identity": null
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "icon": "static/icon.png",
      "category": "Game"
    },
    "forceCodeSigning": false,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "static/icon.ico",
      "uninstallerIcon": "static/icon.ico",
      "installerHeaderIcon": "static/icon.ico"
    },
    "compression": "maximum",
    "extraResources": [
      {
        "from": "../dist/run_server",
        "to": "backend/dist/run_server",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": false
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
