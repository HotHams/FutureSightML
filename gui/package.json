{
  "name": "futuresightml",
  "version": "0.1.0",
  "description": "FutureSightML - Pokemon Team Builder powered by ML",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.futuresightml.app",
    "productName": "FutureSightML",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "static/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "../",
        "to": "backend",
        "filter": [
          "showdown/**",
          "scripts/**",
          "config.yaml",
          "data/**/*.db",
          "data/checkpoints/**",
          "pyproject.toml"
        ]
      }
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
